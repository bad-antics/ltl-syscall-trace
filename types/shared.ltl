// types/shared.ltl — shared type aliases for ltl_syscall_trace

module ltl_syscall_trace::types

pub type Id = int
pub type Name = str
pub type Payload = list<int>

pub enum Status {
    Ok,
    Pending,
    Failed { reason: str },
}

pub struct Meta {
    id: Id,
    name: Name,
    status: Status,
}